# MandiPulse India local environment template
# Copy to .env locally and fill values. Do not commit real secrets.

MANDIPULSE_ENV=local
MANDIPULSE_CONFIG_DIR=configs

# CEDA / AGMARKNET API access
CEDA_API_TOKEN=replace_with_your_ceda_api_token

# Optional fallback if Data.gov.in registration works later
DATA_GOV_IN_API_KEY=replace_with_your_data_gov_in_api_key

# Local service defaults
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=8501
LOG_LEVEL=INFO

# Local MLflow tracking
MLFLOW_TRACKING_URI=./mlruns
